# -----------------------------
# OS / editor junk
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

# JetBrains / PyCharm
.idea/
**/.idea/
*.iml

# VS Code (optional)
.vscode/

# -----------------------------
# Python virtual environments
# -----------------------------
.venv/
venv/
env/
ENV/
venv311/
backend/.venv/
**/.venv/
**/venv/

# Python cache / tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# -----------------------------
# Environment / secrets
# -----------------------------
.env
.env.*
!.env.example
!.env.*.example
backend/.env
!backend/.env.example

# Secret/key files (common)
*.pem
*.key
*.crt
secrets*.json

# -----------------------------
# Database / local runtime files
# -----------------------------
*.db
*.sqlite
*.sqlite3
backend/digital_checkout.db

# Logs
*.log

# -----------------------------
# FastAPI / backend local files
# -----------------------------
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/

# Alembic / migration temp bytecode
backend/migrations/__pycache__/

# -----------------------------
# Android / Kotlin / Gradle
# -----------------------------
.gradle/
**/.gradle/
**/build/
local.properties
captures/
*.apk
*.aab

# Android Studio / IntelliJ extras
*.ipr
*.iws

# Keystores (never commit)
*.jks
*.keystore

# -----------------------------
# Node / web frontend (future-proof)
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Misc temp files
# -----------------------------
*.tmp
*.temp
~$*
